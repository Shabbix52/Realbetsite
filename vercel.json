{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/oauth-callback.html",
      "destination": "/oauth-callback.html"
    },
    {
      "source": "/share/:twitterId",
      "destination": "https://realbetsite-production.up.railway.app/share/:twitterId"
    },
    {
      "source": "/share-image/:twitterId.png",
      "destination": "https://realbetsite-production.up.railway.app/share-image/:twitterId.png"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
